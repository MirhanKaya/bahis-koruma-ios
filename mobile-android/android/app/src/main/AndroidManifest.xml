<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network access -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Required to keep the VPN service alive in the background -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!--
        BIND_VPN_SERVICE:
        Allows the OS to bind to LocalVpnService as a VpnService.
        Without this the system will refuse to establish the TUN interface.
    -->
    <uses-permission android:name="android.permission.BIND_VPN_SERVICE" />

    <application
        android:name="io.flutter.app.FlutterApplication"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:hardwareAccelerated="true">

        <!-- ── Main Activity (Flutter entry point) ────────────────────── -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            LocalVpnService:
            - android:permission="android.permission.BIND_VPN_SERVICE" restricts
              binding to trusted system callers only.
            - The <intent-filter> with action "android.net.VpnService" is
              mandatory for VpnService subclasses.
            - exported="false" prevents third-party apps from starting the service.
        -->
        <service
            android:name=".LocalVpnService"
            android:exported="false"
            android:permission="android.permission.BIND_VPN_SERVICE">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>

    </application>

</manifest>
